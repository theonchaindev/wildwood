generator client {
  provider      = "prisma-client-js"
  // native = local dev (mac); the rest cover Vercel's lambda architectures
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String   @unique
  passHash      String
  wallet        String?  @unique // Solana wallet address (Phantom sign-in)
  save          String? // full game save as JSON
  pendingAcorns Int      @default(0) // proceeds from offers sold while offline
  level         Int      @default(1) // denormalised for the leaderboard
  acorns        Int      @default(0)
  homeTier      Int      @default(0) // denormalised for the estate leaderboard
  houseLevel    Int      @default(1)
  flagged       Int      @default(0) // implausible-earning strikes (anti-cheat)
  lastSeen      DateTime @default(now()) // heartbeat for the online count
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  offers        Offer[]
  payouts       Payout[]
}

// messages visitors leave at someone's homestead
model Guestbook {
  id        String   @id @default(cuid())
  owner     String // homestead owner's player name
  author    String
  text      String
  createdAt DateTime @default(now())

  @@index([owner, createdAt])
}

// player-to-player gifts: tips (acorns) or items, claimed from the Exchange
model Gift {
  id        String   @id @default(cuid())
  toName    String
  fromName  String
  item      String?
  qty       Int      @default(0)
  acorns    Int      @default(0)
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([toName, claimed])
}

// one row per active browser session (guests included) — powers the online
// count AND real-time player positions in the shared forest
model Presence {
  id         String   @id
  name       String   @default("")
  lastSeen   DateTime @default(now())
  x          Float    @default(0)
  z          Float    @default(0)
  rot        Float    @default(0)
  location   String   @default("forest")
  level      Int      @default(1)
  acorns     Int      @default(0) // denormalised for the live leaderboard
  homeTier   Int      @default(0)
  houseLevel Int      @default(1)
  look       String   @default("{}") // appearance/shirt/hat JSON for rendering
}

model Payout {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  wallet    String
  acorns    Int
  lamports  Int
  txSig     String?
  status    String   @default("pending") // pending | paid | failed
  createdAt DateTime @default(now())
}

model Offer {
  id         String   @id @default(cuid())
  seller     User     @relation(fields: [sellerId], references: [id])
  sellerId   String
  sellerName String
  item       String
  qty        Int
  price      Int
  status     String   @default("open") // open | sold | cancelled
  createdAt  DateTime @default(now())
}
